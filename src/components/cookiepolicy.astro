---
const sections = [
  {
    title: "What Are Cookies?",
    content:
      "Cookies are small text files stored on your device when you visit a website. They help improve user experience and website functionality.",
  },
  {
    title: "How We Use Cookies",
    content:
      "We use cookies to remember preferences, analyze traffic, improve performance, and enhance user experience.",
  },
  {
    title: "Types of Cookies We Use",
    content:
      "We may use essential cookies (required for operation), analytics cookies (to understand usage), and functional cookies (to remember preferences).",
  },
  {
    title: "Third-Party Cookies",
    content:
      "We may allow third-party services like analytics or integrations to place cookies on your device to help us improve our services.",
  },
  {
    title: "Managing Cookies",
    content:
      "You can control or disable cookies through your browser settings. However, disabling cookies may affect functionality of the platform.",
  },
  {
    title: "Changes to This Policy",
    content:
      "We may update this Cookie Policy from time to time. Continued use of the service indicates acceptance of the updated policy.",
  },
];
---

<section class="terms">
  <div class="container">
    <div class="terms-header">
      <span class="section-label">Legal</span>
      <h2 class="section-title">Cookie Policy</h2>
      <p class="section-sub">
        Learn how we use cookies and tracking technologies.
      </p>
    </div>

    <div class="terms-list">
      {sections.map((item, i) => (
        <div class="term-item">
          <div class="term-num">
            {(i + 1).toString().padStart(2, "0")}
          </div>
          <div class="term-body">
            <h3>{item.title}</h3>
            <p>{item.content}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* same styling */
  .terms { padding: 100px 0; border-top: 1px solid var(--border); }
  .terms-header { text-align: center; max-width: 700px; margin: 0 auto 60px; }
  .section-label { font-size: 12px; text-transform: uppercase; color: var(--primary); }
  .section-title { font-size: 36px; margin: 10px 0; }
  .section-sub { color: var(--muted); }
  .terms-list { display: flex; flex-direction: column; gap: 30px; max-width: 800px; margin: 0 auto; }
  .term-item { display: flex; gap: 20px; }
  .term-num { font-weight: bold; color: var(--primary); min-width: 40px; }
  .term-body h3 { margin-bottom: 6px; }
  .term-body p { color: var(--muted); line-height: 1.6; }
</style>